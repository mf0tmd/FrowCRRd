{
  "name": "frowcrrd-aerospace-simulation-suite",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop wrapper build for FrowCRRD Aerospace Simulation Suite",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"wait-on http://localhost:3000 && node electron/dev-launch.cjs\"",
    "dev:desktop:core": "npm run build:sim-core && npm run dev:desktop",
    "build": "vite build",
    "build:web": "vite build",
    "build:sim-core": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\build_sim_runner.ps1 -BuildDir build\\gui-release -BuildType Release",
    "build:sim-core:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\build_sim_runner.ps1 -BuildDir build\\gui-debug -BuildType Debug",
    "build:desktop": "npm run build:web && npm run build:sim-core && electron-builder --win nsis-web",
    "build:desktop:offline": "npm run build:web && npm run build:sim-core && electron-builder --win nsis",
    "pack:desktop": "npm run build:web && npm run build:sim-core && electron-builder --dir",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "lucide-react": "^0.562.0",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.frowcrrd.desktop",
    "productName": "FrowCRRD",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../Configs",
        "to": "FrowCRRd/Configs"
      },
      {
        "from": "../build/gui-release/bin",
        "to": "sim-core",
        "filter": [
          "frowcrrd_runner*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis-web",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsisWeb": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
